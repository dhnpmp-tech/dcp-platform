{
  "id": "vllm-serve",
  "name": "vLLM Serve",
  "description": "OpenAI-compatible LLM serving API. Deploy Mistral, Llama, Qwen, and other models with high-throughput batched inference.",
  "image": "dc1/llm-worker:latest",
  "job_type": "llm-inference",
  "env_vars": [
    { "key": "MODEL_ID", "label": "Model ID (HuggingFace)", "default": "mistralai/Mistral-7B-Instruct-v0.2", "required": true },
    { "key": "MAX_TOKENS", "label": "Max Tokens", "default": "512", "required": false },
    { "key": "TEMPERATURE", "label": "Temperature", "default": "0.7", "required": false }
  ],
  "params": {
    "model": "mistralai/Mistral-7B-Instruct-v0.2",
    "prompt": "Hello, tell me about GPU compute.",
    "max_tokens": 512,
    "temperature": 0.7
  },
  "model_cache": {
    "mount_path": "/opt/dcp/model-cache",
    "default_policy": "hot",
    "behavior": "Hot cache keeps tokenizer + weight shards pinned for low-latency serving restarts."
  },
  "example_io": {
    "input": {
      "job_type": "vllm_serve",
      "duration_minutes": 60,
      "params": {
        "model": "mistralai/Mistral-7B-Instruct-v0.2",
        "max_model_len": 8192,
        "dtype": "float16"
      }
    },
    "output": {
      "type": "endpoint",
      "model": "mistralai/Mistral-7B-Instruct-v0.2",
      "status": "running",
      "openai_base_url": "http://127.0.0.1:8000/v1"
    }
  },
  "workflow_contract": {
    "version": "dcp.template_workflow.v1",
    "mode": "pod_local_openai_compatible",
    "workspace_mount": "/workspace",
    "endpoint": {
      "scope": "pod_local",
      "openai_base_url": "http://127.0.0.1:8000/v1",
      "public_route_enabled": false,
      "adapter_load_proof_required": true
    },
    "claim_guards": {
      "catalog_launches_pod": false,
      "catalog_mutates_balance": false,
      "managed_training_enabled": false,
      "public_endpoint_route_enabled": false,
      "adapter_billing_enabled": false,
      "exposes_provider_or_vendor": false,
      "requires_gpu_host_proof": true
    },
    "next_proof": "DCP_ADAPTER_VLLM_LIVE_PROOF_ALLOW=1 npm run proof:adapter-vllm-live-load"
  },
  "min_vram_gb": 16,
  "estimated_price_sar_per_hour": 9.0,
  "default_duration_minutes": 120,
  "default_pricing_class": "standard",
  "tags": ["llm", "inference", "api", "openai-compatible"],
  "sort_order": 1,
  "icon": "🤖",
  "difficulty": "easy"
}
