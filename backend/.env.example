# DCP Backend Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# ── Core ──────────────────────────────────────────────────────────────────────
DC1_ADMIN_TOKEN=change_me_min_32_chars_random
DC1_HMAC_SECRET=change_me_min_32_chars_random

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from your Supabase project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key

# ── Database ──────────────────────────────────────────────────────────────────
DC1_DB_PATH=./data/providers.db

# ── WireGuard Provider Bootstrap ──────────────────────────────────────────────
# Required in production. Public endpoint only; do not put private keys here.
WG_SERVER_ENDPOINT=vpn.dcp.sa:51820

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Optional ──────────────────────────────────────────────────────────────────
# DCP_IMAGE_REGISTRY_ALLOWLIST=docker.io,ghcr.io
# DCP_PRIVATE_REGISTRY=
# DCP_IMAGE_APPROVAL_WINDOW_MINUTES=10
# DCP_IMAGE_APPROVAL_MAX_REQUESTS=20

# ── P2P Network ───────────────────────────────────────────────────────────────
# Bootstrap node multiaddr — set to your deployed bootstrap node
# DCP_P2P_BOOTSTRAP=/ip4/<bootstrap-ip>/tcp/4001/p2p/<peer-id>
# P2P_DISCOVERY_ENABLED=true
