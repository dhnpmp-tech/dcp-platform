# DC1 Platform — Environment Variables
# Copy this file to .env.local and fill in with your values

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── DC1 Backend URL ───────────────────────────────────────────────────────────
# Server-side (Next.js API routes + next.config.js proxy rewrite)
BACKEND_URL=https://api.dcp.sa

# Client-side (browser fetch — used by lib/api.ts when not on HTTPS/Vercel)
NEXT_PUBLIC_DC1_API=https://api.dcp.sa

# ── Mission Control URL ───────────────────────────────────────────────────────
NEXT_PUBLIC_MC_URL=https://mc.dcp.sa

# ── Backend server.js ─────────────────────────────────────────────────────────
# Optional: comma-separated extra origins allowed in CORS (e.g. your staging domain)
# CORS_ORIGINS=https://staging.dcp.sa,http://localhost:3001

# ── Auth ──────────────────────────────────────────────────────────────────────
# DC1_ADMIN_TOKEN is set on the VPS in PM2 env — do NOT commit the real value here
# DC1_ADMIN_TOKEN=your-admin-token-here

# DC1_HMAC_SECRET must be set on the VPS — generate with: openssl rand -hex 32
# DC1_HMAC_SECRET=your-hmac-secret-here

# WireGuard provider bootstrap endpoint. This is not a secret, but production
# backend deploys must set it so /wg/register and /wg/install-config can render
# valid peer configs.
# WG_SERVER_ENDPOINT=vpn.dcp.sa:51820

# ── Vercel Deployment ─────────────────────────────────────────────────────────
# Set BACKEND_URL in Vercel project settings to point to your backend:
#   BACKEND_URL=https://api.dcp.sa
# NEXT_PUBLIC_DC1_API is only used for local dev (Vercel uses /api/dc1 proxy path)
