{
  "name": "dcp-platform-contracts",
  "version": "1.0.0",
  "description": "DCP platform EVM smart contracts for escrow on Base L2",
  "private": true,
  "scripts": {
    "compile": "npx hardhat compile",
    "test": "npx hardhat test",
    "test:gas": "REPORT_GAS=true npx hardhat test",
    "deploy:sepolia": "npx hardhat run scripts/deploy.js --network base-sepolia",
    "verify": "npx hardhat verify --network base-sepolia",
    "clean": "npx hardhat clean"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@openzeppelin/contracts": "^5.0.2",
    "dotenv": "^16.4.5",
    "hardhat": "^2.22.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
