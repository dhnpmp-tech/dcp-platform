{
  "name": "dcp-compute",
  "displayName": "DCP GPU Compute",
  "description": "Submit GPU compute jobs to DCP — Saudi Arabia's decentralized GPU marketplace. Provider sidebar, job submission, live log streaming, wallet panel.",
  "version": "0.4.0",
  "publisher": "dcp-platform",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dhnpmp-tech/dcp-platform"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "GPU",
    "compute",
    "AI",
    "machine learning",
    "DCP",
    "Saudi Arabia",
    "inference"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dc1-explorer",
          "title": "DCP Compute",
          "icon": "media/dc1-icon.svg"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "dc1.providerStatus",
          "name": "DCP Provider",
          "icon": "$(server)",
          "visibility": "collapsed"
        }
      ],
      "dc1-explorer": [
        {
          "id": "dc1.availableGPUs",
          "name": "Available GPUs",
          "icon": "$(server)"
        },
        {
          "id": "dc1.myJobs",
          "name": "My Jobs",
          "icon": "$(play-circle)"
        },
        {
          "id": "dc1.templatesCatalog",
          "name": "Template Catalog",
          "icon": "$(layers)"
        },
        {
          "id": "dc1.modelsCatalog",
          "name": "Model Catalog",
          "icon": "$(symbol-method)"
        }
      ]
    },
    "commands": [
      {
        "command": "dc1.setProviderKey",
        "title": "DCP: Set Provider API Key",
        "icon": "$(key)"
      },
      {
        "command": "dc1.clearProviderKey",
        "title": "DCP: Clear Provider API Key",
        "icon": "$(trash)"
      },
      {
        "command": "dc1.refreshProviderStatus",
        "title": "DCP: Refresh Provider Status",
        "icon": "$(refresh)"
      },
      {
        "command": "dc1.setup",
        "title": "DCP: Set Renter API Key",
        "icon": "$(key)"
      },
      {
        "command": "dc1.submitJob",
        "title": "DCP: Run AI Inference",
        "icon": "$(play)"
      },
      {
        "command": "dc1.submitContainerJob",
        "title": "DCP: Submit Container Job (Advanced)",
        "icon": "$(play)"
      },
      {
        "command": "dc1.watchJobLogs",
        "title": "DCP: Watch Job Logs",
        "icon": "$(output)"
      },
      {
        "command": "dc1.refreshGPUs",
        "title": "DCP: Refresh Available GPUs",
        "icon": "$(refresh)"
      },
      {
        "command": "dc1.refreshJobs",
        "title": "DCP: Refresh My Jobs",
        "icon": "$(refresh)"
      },
      {
        "command": "dc1.viewJobLogs",
        "title": "DCP: View Job Logs",
        "icon": "$(output)"
      },
      {
        "command": "dc1.cancelJob",
        "title": "DCP: Cancel Job",
        "icon": "$(stop)"
      },
      {
        "command": "dc1.openWallet",
        "title": "DCP: Wallet & Billing",
        "icon": "$(credit-card)"
      },
      {
        "command": "dc1.submitJobOnProvider",
        "title": "DCP: Submit Job on This GPU",
        "icon": "$(play)"
      },
      {
        "command": "dc1.openBillingPage",
        "title": "DCP: Open Billing Page",
        "icon": "$(link-external)"
      },
      {
        "command": "dc1.streamLogs",
        "title": "DCP: Stream Job Logs",
        "icon": "$(output)"
      },
      {
        "command": "dc1.stopLogStream",
        "title": "DCP: Stop Log Stream",
        "icon": "$(stop)"
      },
      {
        "command": "dc1.showSettings",
        "title": "DCP: Settings",
        "icon": "$(settings-gear)"
      },
      {
        "command": "dc1.modelStatus",
        "title": "DCP: Model Cache Status",
        "icon": "$(database)"
      },
      {
        "command": "dc1.refreshTemplates",
        "title": "Refresh Templates",
        "icon": "$(refresh)"
      },
      {
        "command": "dc1.refreshModels",
        "title": "Refresh Models",
        "icon": "$(refresh)"
      },
      {
        "command": "dc1.deployTemplate",
        "title": "Deploy Template",
        "icon": "$(play)"
      },
      {
        "command": "dc1.startArabicRagSession",
        "title": "DCP: Start Arabic RAG Session",
        "icon": "$(symbol-method)"
      },
      {
        "command": "dc1.searchTemplates",
        "title": "DCP: Search Templates",
        "icon": "$(search)"
      },
      {
        "command": "dc1.filterTemplatesByVram",
        "title": "DCP: Filter Templates by VRAM",
        "icon": "$(filter)"
      },
      {
        "command": "dc1.clearTemplateFilters",
        "title": "DCP: Clear Template Filters",
        "icon": "$(clear-all)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "dc1.refreshProviderStatus",
          "when": "view == dc1.providerStatus",
          "group": "navigation@1"
        },
        {
          "command": "dc1.setProviderKey",
          "when": "view == dc1.providerStatus",
          "group": "navigation@2"
        },
        {
          "command": "dc1.refreshGPUs",
          "when": "view == dc1.availableGPUs",
          "group": "navigation@2"
        },
        {
          "command": "dc1.submitJob",
          "when": "view == dc1.availableGPUs",
          "group": "navigation@1"
        },
        {
          "command": "dc1.refreshJobs",
          "when": "view == dc1.myJobs",
          "group": "navigation@1"
        },
        {
          "command": "dc1.refreshTemplates",
          "when": "view == dc1.templatesCatalog",
          "group": "navigation@1"
        },
        {
          "command": "dc1.searchTemplates",
          "when": "view == dc1.templatesCatalog",
          "group": "navigation@2"
        },
        {
          "command": "dc1.filterTemplatesByVram",
          "when": "view == dc1.templatesCatalog",
          "group": "navigation@3"
        },
        {
          "command": "dc1.clearTemplateFilters",
          "when": "view == dc1.templatesCatalog",
          "group": "navigation@4"
        },
        {
          "command": "dc1.refreshModels",
          "when": "view == dc1.modelsCatalog",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "dc1.submitJobOnProvider",
          "when": "view == dc1.availableGPUs && viewItem == gpu",
          "group": "inline"
        },
        {
          "command": "dc1.viewJobLogs",
          "when": "view == dc1.myJobs && viewItem == job",
          "group": "inline"
        },
        {
          "command": "dc1.cancelJob",
          "when": "view == dc1.myJobs && viewItem == job_running",
          "group": "inline"
        },
        {
          "command": "dc1.deployTemplate",
          "when": "view == dc1.templatesCatalog && viewItem == template",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "DCP Compute",
      "properties": {
        "dc1.apiBase": {
          "type": "string",
          "default": "https://api.dcp.sa",
          "description": "DCP API base URL."
        },
        "dc1.renterApiKey": {
          "type": "string",
          "default": "",
          "description": "Your DCP renter API key (from dcp.sa/renter/register). Alternatively, use the 'DCP: Set Renter API Key' command to store it securely in VS Code's secret storage."
        },
        "dc1.pollIntervalSeconds": {
          "type": "number",
          "default": 10,
          "minimum": 5,
          "maximum": 60,
          "description": "Job status polling interval in seconds."
        },
        "dc1.autoRefreshGPUs": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh available GPUs every 30 seconds."
        },
        "dc1.autoRefreshTemplates": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh template catalog every 5 minutes."
        },
        "dc1.autoRefreshModels": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh model catalog every 5 minutes."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack --mode development",
    "watch": "webpack --mode development --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "lint": "eslint src --ext ts",
    "test": "echo \"No tests yet\""
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.9.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  }
}
